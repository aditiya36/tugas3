---
// halaman utama - menampilkan data crypto dari API Coinlore
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Aplikasi Crypto Tracker - Tugas Mobile Programming" />
    <title>Crypto Tracker</title>
  </head>
  <body class="bg-#0B0E11 text-#EAECEF font-sans min-h-screen m-0 p-0">

    <!-- header aplikasi -->
    <header class="sticky top-0 z-50 bg-#1E2329 border-b border-#2B3139 backdrop-blur-md">
      <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-#FCD535 rounded-lg flex items-center justify-center">
            <span class="text-#0B0E11 font-700 text-lg">₿</span>
          </div>
          <div>
            <h1 class="text-base font-700 m-0 leading-tight">Crypto Tracker</h1>
            <p class="text-xs text-#848E9C m-0">Live Market Data</p>
          </div>
        </div>
        <div id="lastUpdate" class="text-xs text-#848E9C text-right">
          Loading...
        </div>
      </div>
    </header>

    <!-- tombol refresh -->
    <div class="max-w-lg mx-auto px-4 pt-4 pb-2">
      <button
        id="btnRefresh"
        class="w-full py-3.5 bg-#FCD535 hover:bg-#E5C130 text-#0B0E11 font-700 text-sm rounded-xl border-none cursor-pointer transition-all duration-200 flex items-center justify-center gap-2 active:scale-98"
      >
        <span id="refreshIcon" class="text-base transition-transform duration-500">⟳</span>
        <span id="refreshText">Refresh Data</span>
      </button>
    </div>

    <!-- info ringkasan -->
    <div class="max-w-lg mx-auto px-4 py-2">
      <div class="flex items-center justify-between text-xs text-#848E9C">
        <span id="totalCoins">Memuat data...</span>
        <span class="flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-#0ECB81 inline-block"></span>
          API Coinlore
        </span>
      </div>
    </div>

    <!-- container untuk list crypto -->
    <main class="max-w-lg mx-auto px-4 pb-8">
      <div id="listContainer" class="flex flex-col gap-2">
        <!-- data akan di-render lewat javascript -->
      </div>

      <!-- loading skeleton -->
      <div id="skeleton" class="flex flex-col gap-2">
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
        <div class="h-18 bg-#1E2329 rounded-xl animate-pulse"></div>
      </div>

      <!-- pesan error -->
      <div id="errorMsg" class="hidden text-center py-12">
        <div class="text-4xl mb-3">⚠️</div>
        <p class="text-#848E9C text-sm m-0">Gagal memuat data. Cek koneksi internet kamu.</p>
        <button
          onclick="fetchCryptoData()"
          class="mt-4 px-6 py-2 bg-#2B3139 text-#EAECEF text-xs rounded-lg border border-#2B3139 cursor-pointer hover:bg-#3C4450 transition-colors"
        >
          Coba Lagi
        </button>
      </div>
    </main>

    <!-- footer: info tugas + credit -->
    <footer class="max-w-lg mx-auto px-4 pb-6 text-center">
      <div class="border-t border-#2B3139 pt-5 mt-4">
        <p class="text-xs font-600 text-#EAECEF m-0 mb-1">Tugas Praktikum 3</p>
        <p class="text-xs text-#848E9C m-0 leading-relaxed">
          Rizka Aditiya Setiyawan — 050932145
        </p>
        <p class="text-xs text-#848E9C m-0 mt-0.5">
          Pemrograman Berbasis Perangkat Bergerak
        </p>
        <p class="text-xs text-#848E9C m-0 mt-3 opacity-60">
          Data dari
          <a href="https://www.coinlore.com/" target="_blank" class="text-#FCD535 no-underline hover:underline">Coinlore API</a>
        </p>
      </div>
    </footer>

    <style is:global>
      /* animasi spin buat icon refresh */
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .spinning {
        animation: spin 0.8s linear infinite;
        display: inline-block;
      }

      /* animasi fade-in buat card */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-up {
        animation: fadeUp 0.35s ease-out forwards;
      }

      /* scrollbar custom biar makin keren */
      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: #0B0E11;
      }
      ::-webkit-scrollbar-thumb {
        background: #2B3139;
        border-radius: 4px;
      }
    </style>

    <script is:inline>
      // ambil elemen-elemen yang dibutuhin
      const listContainer = document.getElementById('listContainer');
      const skeleton = document.getElementById('skeleton');
      const errorMsg = document.getElementById('errorMsg');
      const btnRefresh = document.getElementById('btnRefresh');
      const refreshIcon = document.getElementById('refreshIcon');
      const refreshText = document.getElementById('refreshText');
      const lastUpdate = document.getElementById('lastUpdate');
      const totalCoins = document.getElementById('totalCoins');

      // variabel buat nyimpen state
      let isLoading = false;

      // fungsi utama: fetch data dari api coinlore
      async function fetchCryptoData() {
        if (isLoading) return; // cegah double fetch
        isLoading = true;

        // tampilin loading state
        showLoading(true);
        errorMsg.classList.add('hidden');
        listContainer.innerHTML = '';

        try {
          // fetch data dari coinlore
          const response = await fetch('https://api.coinlore.net/api/tickers/');
          if (!response.ok) throw new Error('Gagal fetch data');

          const result = await response.json();
          const cryptoData = result.data;

          // sembunyiin skeleton, render data
          showLoading(false);
          renderCryptoList(cryptoData);

          // update info
          totalCoins.textContent = `Menampilkan ${cryptoData.length} koin`;
          lastUpdate.innerHTML = `Update: ${getWaktuSekarang()}`;

        } catch (error) {
          // kalo error, tampilin pesan error
          console.error('Error fetch data:', error);
          showLoading(false);
          errorMsg.classList.remove('hidden');
          totalCoins.textContent = 'Gagal memuat data';
        } finally {
          isLoading = false;
        }
      }

      // render list koin ke html
      function renderCryptoList(data) {
        let html = '';

        data.forEach((coin, index) => {
          // tentuin warna perubahan harga
          const priceChange = parseFloat(coin.percent_change_24h);
          const changeColor = priceChange >= 0 ? '#0ECB81' : '#F6465D';
          const changeSign = priceChange >= 0 ? '+' : '';

          // format harga biar rapi
          const hargaFormatted = formatHarga(coin.price_usd);

          html += `
            <div class="fade-up" style="animation-delay: ${index * 0.04}s; opacity: 0;">
              <div style="
                background: #1E2329;
                border-radius: 12px;
                padding: 14px 16px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border: 1px solid #2B3139;
                transition: background 0.2s, border-color 0.2s;
                cursor: pointer;
              "
              onmouseover="this.style.background='#2B3139'; this.style.borderColor='#3C4450';"
              onmouseout="this.style.background='#1E2329'; this.style.borderColor='#2B3139';"
              >
                <!-- bagian kiri: rank + nama -->
                <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                  <div style="
                    width: 36px;
                    height: 36px;
                    border-radius: 10px;
                    background: ${getRankColor(coin.rank)};
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 700;
                    font-size: 13px;
                    color: #0B0E11;
                    flex-shrink: 0;
                  ">
                    ${coin.rank}
                  </div>
                  <div style="min-width: 0;">
                    <div style="font-weight: 600; font-size: 14px; color: #EAECEF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                      ${coin.name}
                    </div>
                    <div style="font-size: 12px; color: #848E9C; margin-top: 2px;">
                      ${coin.symbol}
                    </div>
                  </div>
                </div>

                <!-- bagian kanan: harga -->
                <div style="text-align: right; flex-shrink: 0; padding-left: 12px;">
                  <div style="font-weight: 600; font-size: 14px; color: #EAECEF; font-family: 'JetBrains Mono', monospace;">
                    <span style="color: #848E9C; font-weight: 400; font-size: 11px;">USD </span>
                    ${hargaFormatted}
                  </div>
                  <div style="font-size: 12px; color: ${changeColor}; margin-top: 2px; font-family: 'JetBrains Mono', monospace;">
                    ${changeSign}${priceChange.toFixed(2)}%
                  </div>
                </div>
              </div>
            </div>
          `;
        });

        listContainer.innerHTML = html;
      }

      // format harga biar ada koma dan desimalnya rapi
      function formatHarga(price) {
        const num = parseFloat(price);
        if (num >= 1) {
          return num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        } else {
          return num.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 6 });
        }
      }

      // warna rank: top 3 dapet warna spesial
      function getRankColor(rank) {
        if (rank == 1) return '#FCD535'; // emas
        if (rank == 2) return '#B8B8B8'; // perak
        if (rank == 3) return '#CD7F32'; // perunggu
        return '#3C4450'; // default abu-abu
      }

      // ambil waktu sekarang, format simple
      function getWaktuSekarang() {
        const now = new Date();
        const jam = String(now.getHours()).padStart(2, '0');
        const menit = String(now.getMinutes()).padStart(2, '0');
        const detik = String(now.getSeconds()).padStart(2, '0');
        return `${jam}:${menit}:${detik}`;
      }

      // toggle loading state
      function showLoading(show) {
        skeleton.style.display = show ? 'flex' : 'none';
        if (show) {
          refreshIcon.classList.add('spinning');
          refreshText.textContent = 'Memuat...';
          btnRefresh.disabled = true;
          btnRefresh.style.opacity = '0.7';
        } else {
          refreshIcon.classList.remove('spinning');
          refreshText.textContent = 'Refresh Data';
          btnRefresh.disabled = false;
          btnRefresh.style.opacity = '1';
        }
      }

      // event listener tombol refresh
      btnRefresh.addEventListener('click', () => {
        fetchCryptoData();
      });

      // auto fetch pas halaman pertama kali dibuka
      fetchCryptoData();
    </script>

  </body>
</html>
